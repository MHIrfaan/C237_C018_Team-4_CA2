<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>StudyTrack - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f4f7f6 !important; color: #2b3440; }
        .navbar-admin { background: linear-gradient(135deg, #1e293b, #0f172a); padding: 1rem 0; }
        .card { border: none; border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.04); overflow: hidden; }
        .card-stat-1 { background: linear-gradient(135deg, #6366f1, #3b82f6); color: white; }
        .card-stat-2 { background: linear-gradient(135deg, #14b8a6, #06b6d4); color: white; }
        .card-stat-3 { background: linear-gradient(135deg, #8b5cf6, #d946ef); color: white; }
        .btn { border-radius: 8px; font-weight: 500; }
        .table > :not(caption) > * > * { padding: 1rem 1.5rem; border-bottom-color: #f1f5f9; }
        .table th { text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; color: #64748b; font-weight: 600; background-color: #f8fafc; border-bottom: none; }
        .card-header { border-bottom: 1px solid #edf2f7; padding: 1.25rem 1.5rem; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark navbar-admin shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/admin">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" style="width: 32px; height: 32px; border-radius: 8px;">
              <rect width="100" height="100" rx="22" fill="#ffffff" />
              <polygon points="50,22 15,37 50,52 85,37" fill="#0f172a" />
              <path d="M25,43 L25,60 Q50,80 75,60 L75,43" fill="none" stroke="#0f172a" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            StudyTrack Admin
        </a>
        <div class="d-flex align-items-center">
            <span class="text-white me-3 opacity-75">Admin Portal: <strong><%= user.username %></strong></span>
            <a href="/logout" class="btn btn-sm btn-light fw-bold px-3">Logout</a>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <h2 class="fw-bold mb-4">System Overview</h2>

    <div class="row mb-5 g-4">
        <div class="col-md-4">
            <div class="card card-stat-1 p-4 h-100">
                <h6 class="opacity-75 text-uppercase fw-bold letter-spacing-1 mb-1">Total Users</h6>
                <h1 class="display-5 fw-bold mb-0"><%= stats.totalUsers %></h1>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-stat-2 p-4 h-100">
                <h6 class="opacity-75 text-uppercase fw-bold letter-spacing-1 mb-1">Active Tasks</h6>
                <h1 class="display-5 fw-bold mb-0"><%= stats.totalTasks %></h1>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-stat-3 p-4 h-100">
                <h6 class="opacity-75 text-uppercase fw-bold letter-spacing-1 mb-1">Global Completion</h6>
                <h1 class="display-5 fw-bold mb-0"><%= stats.completionRate %>%</h1>
            </div>
        </div>
    </div>

    <!-- MANAGE USERS -->
    <div class="card mb-5">
        <div class="card-header bg-white">
            <h5 class="fw-bold text-dark mb-0">Manage Users & Progression</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Overall Progress</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <!-- FIXED: Avatar Trick implemented properly to load ID images -->
                                    <img src="/images/profile_<%= u.id %>.jpg" onerror="this.onerror=null; this.src='/images/profile icon_5.webp';" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; border: 2px solid #e2e8f0;" alt="Avatar">
                                    <div>
                                        <div class="fw-bold"><%= u.username %></div>
                                        <div class="text-muted small">#<%= u.id %></div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted"><%= u.email %></td>
                            <td>
                                <% if(u.role === 'admin') { %>
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25">Admin</span>
                                <% } else { %>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">Student</span>
                                <% } %>
                            </td>
                            <td style="width: 25%;">
                                <% const progressVal = u.progress || 0; %>
                                <% const barColor = progressVal === 100 ? 'bg-success' : (progressVal < 50 ? 'bg-danger' : 'bg-warning'); %>
                                <% const progressStyle = 'style="width: ' + progressVal + '%;"'; %>
                                
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress w-100" style="height: 8px;">
                                        <div class="progress-bar <%= barColor %>" role="progressbar" <%- progressStyle %> aria-valuenow="<%= progressVal %>" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <span class="small fw-semibold text-muted"><%= progressVal %>%</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <% if(u.id !== user.id) { %>
                                    <a href="/admin/delete_user/<%= u.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this user completely?')">Remove</a>
                                <% } else { %>
                                    <span class="text-muted fst-italic small pe-3">Current Session</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- MONITOR PROGRESS -->
    <div class="card mb-5">
        <div class="card-header bg-white">
            <h5 class="fw-bold text-dark mb-0">Monitor Content (All Tasks)</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Task Title</th>
                        <th>Module</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(tasks.length === 0) { %>
                        <tr><td colspan="5" class="text-center py-4">No tasks in the system yet.</td></tr>
                    <% } else { %>
                        <% tasks.forEach(task => { %>
                            <tr>
                                <td class="fw-bold text-primary"><%= task.username %></td>
                                <td><%= task.title %></td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25"><%= task.module %></span></td>
                                <td>
                                    <% if(task.status === 'Completed') { %><span class="text-success fw-bold small">Completed</span><% } %>
                                    <% if(task.status === 'In Progress') { %><span class="text-warning fw-bold small">In Progress</span><% } %>
                                    <% if(task.status === 'Pending') { %><span class="text-muted fw-bold small">Pending</span><% } %>
                                </td>
                                <td class="text-end">
                                    <a href="/admin/delete_task/<%= task.id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this student task?')">Delete</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>