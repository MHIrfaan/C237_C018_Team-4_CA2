<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>StudyTrack - Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; overflow-x: hidden; }
        .form-side { height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 40px; background-color: white; box-shadow: 5px 0 15px rgba(0,0,0,0.1); z-index: 1; overflow-y: auto; }
        .login-container { max-width: 420px; width: 100%; margin: auto; }
        .image-side { height: 100vh; padding: 0; }
        .image-side img { width: 100%; height: 100%; object-fit: cover; }
    </style>
</head>
<body>

<div class="row g-0 vh-100">
    <div class="col-lg-5 col-md-6 form-side">
        <div class="login-container">
            <div class="d-flex justify-content-center align-items-center mb-2 gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" style="width: 45px; height: 45px;">
                    <rect width="100" height="100" rx="22" fill="#e7f1ff" />
                    <polygon points="50,22 15,37 50,52 85,37" fill="#0d6efd" />
                    <path d="M25,43 L25,60 Q50,80 75,60 L75,43" fill="none" stroke="#0d6efd" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M50,37 Q75,37 75,55 L75,70" fill="none" stroke="#0a58ca" stroke-width="5" stroke-linecap="round" />
                    <circle cx="50" cy="37" r="4" fill="#0a58ca" />
                    <circle cx="75" cy="72" r="7" fill="#0a58ca" />
                    <circle cx="75" cy="72" r="3" fill="#e7f1ff" />
                </svg>
                <h2 class="text-primary fw-bold mb-0">StudyTrack</h2>
            </div>
            
            <p class="text-muted text-center mb-4">Create your account</p>

            <% if(success){ %> <script> alert("<%= success %>"); window.location.href = "/login"; </script> <% } %>
            <% if(error){ %> <div class="alert alert-danger text-center p-2"><%= error %></div> <% } %>

            <form action="/register" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Username</label>
                    <input type="text" class="form-control" name="username" value="<%= username %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" class="form-control" name="email" value="<%= email %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold text-dark">Admin Code (Optional)</label>
                    <input type="password" class="form-control" name="adminCode" placeholder="Leave blank if you are a student">
                    <div class="form-text small mt-1">Only enter a code if you are registering as an administrator.</div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Password</label>
                        <input type="password" class="form-control" name="password" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Confirm Password</label>
                        <input type="password" class="form-control" name="confirmPassword" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Address</label>
                    <input type="text" class="form-control" name="address" value="<%= address %>" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Contact Number</label>
                    <input type="text" class="form-control" name="contact" value="<%= contact %>" required>
                </div>

                <button type="submit" class="btn btn-primary w-100 fw-bold mt-2 py-2">Register</button>
            </form>

            <p class="text-center mt-4 mb-0">
                Already have an account? <a href="/login" class="text-decoration-none">Login here</a>
            </p>
        </div>
    </div>

    <div class="col-lg-7 col-md-6 image-side d-none d-md-block">
        <img src="/images/students.png" alt="Students walking on campus">
    </div>
</div>

</body>
</html>