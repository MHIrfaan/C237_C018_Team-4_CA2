<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>StudyTrack - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #eef4fb;
            color: #1e293b;
        }
        .navbar {
            background: linear-gradient(135deg, #2563eb, #0f172a);
            padding: 1rem 0;
        }
        .navbar-brand {
            letter-spacing: 0.02em;
        }
        .hero-card,
        .metric-card,
        .card {
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 45px rgba(15,23,42,0.08);
        }
        .hero-card {
            background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(241,245,249,0.96));
        }
        .metric-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .metric-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 24px 50px rgba(15,23,42,0.12);
        }
        .btn {
            border-radius: 12px;
            font-weight: 600;
        }
        .btn-primary {
            background: #2563eb;
            border: none;
        }
        .btn-primary:hover {
            background: #1d4ed8;
        }
        .btn-outline-primary {
            border-radius: 12px;
        }
        .table {
            border-collapse: separate;
            border-spacing: 0 0.75rem;
        }
        .table th,
        .table td {
            vertical-align: middle;
            border: none;
        }
        .table thead th {
            background: transparent;
            color: #64748b;
            font-size: 0.78rem;
            letter-spacing: 0.08em;
        }
        .table tbody tr {
            background: #fff;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .table tbody tr:hover {
            transform: translateX(3px);
            box-shadow: 0 14px 25px rgba(15,23,42,0.06);
        }
        .table tbody tr td:first-child {
            border-top-left-radius: 18px;
            border-bottom-left-radius: 18px;
        }
        .table tbody tr td:last-child {
            border-top-right-radius: 18px;
            border-bottom-right-radius: 18px;
        }
        .badge {
            padding: 0.5rem 0.8rem;
            border-radius: 12px;
            font-weight: 600;
        }
        .status-chip {
            min-width: 100px;
        }
        .highlight-box {
            border-radius: 22px;
            padding: 1.5rem;
            background: linear-gradient(135deg, rgba(37,99,235,0.12), rgba(99,102,241,0.08));
        }
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
    <div class="container">
        <!-- Inline SVG Logo for Navbar -->
        <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/dashboard">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" style="width: 32px; height: 32px; border-radius: 8px;">
              <rect width="100" height="100" rx="22" fill="#e7f1ff" />
              <polygon points="50,22 15,37 50,52 85,37" fill="#0d6efd" />
              <path d="M25,43 L25,60 Q50,80 75,60 L75,43" fill="none" stroke="#0d6efd" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M50,37 Q75,37 75,55 L75,70" fill="none" stroke="#0a58ca" stroke-width="5" stroke-linecap="round" />
              <circle cx="50" cy="37" r="4" fill="#0a58ca" />
              <circle cx="75" cy="72" r="7" fill="#0a58ca" />
              <circle cx="75" cy="72" r="3" fill="#e7f1ff" />
            </svg>
            StudyTrack
        </a>
        <div class="d-flex align-items-center">
            <span class="text-white me-3 opacity-75">Welcome back, <strong><%= user.username %></strong>!</span>
            <a href="/logout" class="btn btn-sm btn-light text-primary fw-bold px-3">Logout</a>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <div class="row gy-4">
        <div class="col-12">
            <div class="hero-card p-4 p-lg-5">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="display-6 fw-bold mb-3">Track your study goals with ease.</h1>
                        <p class="lead text-muted mb-4">Stay on top of deadlines, priorities, and progress with a crisp task dashboard built for students.</p>
                        <a href="/task/add" class="btn btn-primary btn-lg">Add new task</a>
                    </div>
                    <div class="col-md-4 mt-4 mt-md-0">
                        <div class="highlight-box">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div>
                                    <p class="mb-1 text-uppercase text-primary fw-semibold small">Your progress</p>
                                    <h2 class="mb-0 display-6 fw-bold"><%= tasks.length %></h2>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-primary bg-opacity-10 text-primary">Total</span>
                                </div>
                            </div>
                            <p class="text-muted mb-0">Quick summary of the work you've planned. Keep moving and cross off what matters most.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="metric-card p-4">
                <p class="text-uppercase small text-muted mb-2">Active tasks</p>
                <h3 class="fw-bold mb-1"><%= tasks.filter(task => task.status !== 'Completed').length %></h3>
                <p class="text-muted mb-0">Tasks still in progress or pending.</p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="metric-card p-4">
                <p class="text-uppercase small text-muted mb-2">Completed</p>
                <h3 class="fw-bold mb-1"><%= tasks.filter(task => task.status === 'Completed').length %></h3>
                <p class="text-muted mb-0">Tasks you’ve finished so far.</p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="metric-card p-4">
                <p class="text-uppercase small text-muted mb-2">High priority</p>
                <h3 class="fw-bold mb-1"><%= tasks.filter(task => task.priority === 'High').length %></h3>
                <p class="text-muted mb-0">Tasks needing your attention first.</p>
            </div>
        </div>

        <div class="col-12">
            <div class="card overflow-hidden">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">Task list</h2>
                            <p class="text-muted mb-0">Organized by deadline, module, and status.</p>
                        </div>
                        <a href="/task/add" class="btn btn-outline-primary">Create task</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Module</th>
                                    <th>Type</th>
                                    <th>Priority</th>
                                    <th>Deadline</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(tasks.length === 0) { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">
                                            <div class="mb-3 fs-1">📚</div>
                                            <div class="fw-semibold mb-2">No tasks yet</div>
                                            <div>Add your first study task to start tracking.</div>
                                        </td>
                                    </tr>
                                <% } else { %>
                                    <% tasks.forEach(task => { %>
                                        <tr>
                                            <td class="fw-semibold text-dark"><%= task.title %></td>
                                            <td><span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25"><%= task.module %></span></td>
                                            <td class="text-muted small fw-medium"><%= task.task_type %></td>
                                            <td>
                                                <% if(task.priority === 'High') { %><span class="text-danger fw-bold small">High</span><% } %>
                                                <% if(task.priority === 'Medium') { %><span class="text-warning fw-bold small">Medium</span><% } %>
                                                <% if(task.priority === 'Low') { %><span class="text-success fw-bold small">Low</span><% } %>
                                            </td>
                                            <td class="text-muted fw-semibold"><%= task.deadline %></td>
                                            <td>
                                                <% if(task.status === 'Completed') { %>
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 status-chip">Completed</span>
                                                <% } else if(task.status === 'In Progress') { %>
                                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 status-chip">In Progress</span>
                                                <% } else { %>
                                                    <span class="badge bg-light text-dark border status-chip">Pending</span>
                                                <% } %>
                                            </td>
                                            <td class="text-end">
                                                <a href="/task/edit/<%= task.id %>" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                                <form action="/task/complete/<%= task.id %>" method="POST" class="d-inline">
                                                    <% if(task.status === 'Completed') { %>
                                                        <button type="submit" class="btn btn-sm btn-outline-secondary me-1">Undo</button>
                                                    <% } else { %>
                                                        <button type="submit" class="btn btn-sm btn-outline-success me-1">Complete</button>
                                                    <% } %>
                                                </form>
                                                <form action="/task/delete/<%= task.id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this task? This cannot be undone.');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>