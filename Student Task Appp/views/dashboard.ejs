<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>StudyTrack - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #eef4fb;
            color: #1e293b;
        }

        .navbar {
            background: linear-gradient(135deg, #2563eb, #0f172a);
            padding: 1rem 0;
        }

        .navbar-brand {
            letter-spacing: 0.02em;
        }

        .hero-card,
        .metric-card,
        .card {
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
        }

        .hero-card {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(241, 245, 249, 0.96));
        }

        .metric-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .metric-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 24px 50px rgba(15, 23, 42, 0.12);
        }

        .btn {
            border-radius: 12px;
            font-weight: 600;
        }

        .btn-primary {
            background: #2563eb;
            border: none;
        }

        .btn-primary:hover {
            background: #1d4ed8;
        }

        .btn-outline-primary {
            border-radius: 12px;
        }

        .table {
            border-collapse: separate;
            border-spacing: 0 0.75rem;
        }

        .table th,
        .table td {
            vertical-align: middle;
            border: none;
        }

        .table thead th {
            background: transparent;
            color: #64748b;
            font-size: 0.78rem;
            letter-spacing: 0.08em;
        }

        .table tbody tr {
            background: #fff;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .table tbody tr:hover {
            transform: translateX(3px);
            box-shadow: 0 14px 25px rgba(15, 23, 42, 0.06);
        }

        .table tbody tr td:first-child {
            border-top-left-radius: 18px;
            border-bottom-left-radius: 18px;
        }

        .table tbody tr td:last-child {
            border-top-right-radius: 18px;
            border-bottom-right-radius: 18px;
        }

        .badge {
            padding: 0.5rem 0.8rem;
            border-radius: 12px;
            font-weight: 600;
        }

        .status-chip {
            min-width: 100px;
        }

        .highlight-box {
            border-radius: 22px;
            padding: 1.5rem;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.12), rgba(99, 102, 241, 0.08));
        }

        .calendar-card {
            min-height: 440px;
        }

        .calendar-board {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 0.75rem;
        }

        .calendar-board .day-name {
            text-align: center;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #475569;
            padding-bottom: 0.5rem;
        }

        .calendar-day {
            min-height: 110px;
            background: #f8fafc;
            border-radius: 20px;
            padding: 1rem;
            position: relative;
            border: 1px solid rgba(148, 163, 184, 0.18);
            cursor: pointer;
            transition: transform 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
        }

        .calendar-day:hover {
            transform: translateY(-1px);
            background: #eef2ff;
            border-color: rgba(37, 99, 235, 0.3);
        }

        .calendar-day.empty {
            background: transparent;
            border: none;
            box-shadow: none;
            cursor: default;
        }

        .calendar-day.today {
            background: #e0e7ff;
            border-color: #2563eb;
        }

        .calendar-day .date-number {
            position: absolute;
            top: 1rem;
            right: 1rem;
            font-size: 0.85rem;
            font-weight: 700;
            color: #334155;
        }

        .calendar-event {
            margin-top: 2.4rem;
            padding: 0.5rem 0.75rem;
            border-radius: 14px;
            background: #2563eb;
            color: #ffffff;
            font-size: 0.78rem;
            line-height: 1.2;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .calendar-more {
            margin-top: 0.5rem;
            color: #2563eb;
            font-size: 0.8rem;
            font-weight: 700;
        }

        .calendar-nav-btn {
            width: 2.25rem;
            height: 2.25rem;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            font-size: 0.95rem;
        }

        .task-search-group {
            max-width: 280px;
            width: 100%;
        }

        .task-search-group .input-group-text {
            background: #fff;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
        <div class="container">
            <!-- Inline SVG Logo for Navbar -->
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/dashboard">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"
                    style="width: 32px; height: 32px; border-radius: 8px;">
                    <rect width="100" height="100" rx="22" fill="#e7f1ff" />
                    <polygon points="50,22 15,37 50,52 85,37" fill="#0d6efd" />
                    <path d="M25,43 L25,60 Q50,80 75,60 L75,43" fill="none" stroke="#0d6efd" stroke-width="6"
                        stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M50,37 Q75,37 75,55 L75,70" fill="none" stroke="#0a58ca" stroke-width="5"
                        stroke-linecap="round" />
                    <circle cx="50" cy="37" r="4" fill="#0a58ca" />
                    <circle cx="75" cy="72" r="7" fill="#0a58ca" />
                    <circle cx="75" cy="72" r="3" fill="#e7f1ff" />
                </svg>
                StudyTrack
            </a>
            
            <div class="d-flex align-items-center">
                <!-- User Avatar added next to Welcome message -->
                <img
                    src="/images/<%= user.profile_pic || 'profile_icon.webp' %>"
                    onerror="this.onerror=null; this.src='/images/profile_icon.webp';"
                    alt="Avatar"
                    class="rounded-circle me-2"
                    style="width: 32px; height: 32px; object-fit: cover; border: 2px solid rgba(255,255,255,0.2);"
                >
                <span class="text-white me-3 opacity-75">Welcome back, <strong><%= user.username %></strong>!</span>
                
                <!-- Added Edit Profile Button -->
                <a href="/profile" class="btn btn-sm btn-outline-light me-2 fw-bold px-3">Edit Profile</a>
                <a href="/logout" class="btn btn-sm btn-light text-primary fw-bold px-3">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <ul class="nav nav-tabs mb-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home-tab-pane"
                    type="button" role="tab" aria-controls="home-tab-pane" aria-selected="true">Home</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tasks-tab" data-bs-toggle="tab" data-bs-target="#tasks-tab-pane"
                    type="button" role="tab" aria-controls="tasks-tab-pane" aria-selected="false">My Tasks</button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="home-tab-pane" role="tabpanel" aria-labelledby="home-tab">
                <div class="row gy-4">
                    <div class="col-12">
                        <div class="hero-card p-4 p-lg-5">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h1 class="display-6 fw-bold mb-3">Track your study goals with ease.</h1>
                                    <p class="lead text-muted mb-4">Stay on top of deadlines, priorities, and progress
                                        with a crisp task dashboard built for students.</p>
                                    <a href="/task/add" class="btn btn-primary btn-lg">Add new task</a>
                                </div>
                                <div class="col-md-4 mt-4 mt-md-0">
                                    <div class="highlight-box">
                                        <div class="d-flex align-items-center justify-content-between mb-3">
                                            <div>
                                                <p class="mb-1 text-uppercase text-primary fw-semibold small">Your
                                                    progress</p>
                                                <h2 class="mb-0 display-6 fw-bold">
                                                    <%= tasks.length %>
                                                </h2>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-primary bg-opacity-10 text-primary">Total</span>
                                            </div>
                                        </div>
                                        <p class="text-muted mb-0">Quick summary of the work you've planned. Keep moving
                                            and cross off what matters most.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="metric-card p-4">
                            <p class="text-uppercase small text-muted mb-2">Active tasks</p>
                            <h3 class="fw-bold mb-1">
                                <%= tasks.filter(task=> task.status !== 'Completed').length %>
                            </h3>
                            <p class="text-muted mb-0">Tasks still in progress or pending.</p>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="metric-card p-4">
                            <p class="text-uppercase small text-muted mb-2">Completed</p>
                            <h3 class="fw-bold mb-1">
                                <%= tasks.filter(task=> task.status === 'Completed').length %>
                            </h3>
                            <p class="text-muted mb-0">Tasks you’ve finished so far.</p>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="metric-card p-4">
                            <p class="text-uppercase small text-muted mb-2">High priority</p>
                            <h3 class="fw-bold mb-1">
                                <%= tasks.filter(task=> task.priority === 'High').length %>
                            </h3>
                            <p class="text-muted mb-0">Tasks needing your attention first.</p>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="card calendar-card p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h4 class="fw-bold mb-1">Study calendar</h4>
                                    <p class="text-muted mb-0">See deadlines and upcoming work for this month.</p>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <button class="btn btn-outline-secondary calendar-nav-btn" id="prevMonth"
                                        type="button">&lt;</button>
                                    <div class="text-dark fw-semibold" id="calendarMonth"></div>
                                    <button class="btn btn-outline-secondary calendar-nav-btn" id="nextMonth"
                                        type="button">&gt;</button>
                                </div>
                            </div>
                            <div class="calendar-board" id="calendarGrid"></div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card p-4">
                            <h5 class="fw-bold mb-3">Upcoming deadlines</h5>
                            <div id="upcomingList"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tasks-tab-pane" role="tabpanel" aria-labelledby="tasks-tab">
                <div class="card overflow-hidden">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                            <div>
                                <h2 class="fw-bold mb-1">My tasks</h2>
                                <p class="text-muted mb-0">Organized by deadline, module, and status.</p>
                            </div>
                            <div class="d-flex align-items-center flex-wrap gap-2">
                                <div class="input-group task-search-group">
                                    <span class="input-group-text border-end-0">🔍</span>
                                    <input type="text" id="taskSearchInput" class="form-control border-start-0"
                                        placeholder="Search tasks..." aria-label="Search tasks">
                                </div>
                                <select id="moduleFilterSelect" class="form-select" style="max-width: 170px;"
                                    aria-label="Filter by module">
                                    <option value="">All modules</option>
                                </select>
                                <select id="taskSortSelect" class="form-select" style="max-width: 190px;"
                                    aria-label="Sort tasks">
                                    <option value="deadline-asc">Deadline: Earliest</option>
                                    <option value="deadline-desc">Deadline: Latest</option>
                                    <option value="status">Status</option>
                                </select>
                                <a href="/task/add" class="btn btn-outline-primary text-nowrap">Create task</a>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Module</th>
                                        <th>Type</th>
                                        <th>Priority</th>
                                        <th>Deadline</th>
                                        <th>Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="tasksTableBody">
                                    <% if(tasks.length===0) { %>
                                        <tr>
                                            <td colspan="7" class="text-center py-5 text-muted">
                                                <div class="mb-3 fs-1">📚</div>
                                                <div class="fw-semibold mb-2">No tasks yet</div>
                                                <div>Add your first study task to start tracking.</div>
                                            </td>
                                        </tr>
                                        <% } else { %>
                                            <% tasks.forEach(task=> { %>
                                                <tr data-module="<%= task.module %>" data-status="<%= task.status %>"
                                                    data-deadline="<%= task.deadline %>">
                                                    <td class="fw-semibold text-dark">
                                                        <%= task.title %>
                                                    </td>
                                                    <td><span
                                                            class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">
                                                            <%= task.module %>
                                                        </span></td>
                                                    <td class="text-muted small fw-medium">
                                                        <%= task.task_type %>
                                                    </td>
                                                    <td>
                                                        <% if(task.priority==='High' ) { %><span
                                                                class="text-danger fw-bold small">High</span>
                                                            <% } %>
                                                                <% if(task.priority==='Medium' ) { %><span
                                                                        class="text-warning fw-bold small">Medium</span>
                                                                    <% } %>
                                                                        <% if(task.priority==='Low' ) { %><span
                                                                                class="text-success fw-bold small">Low</span>
                                                                            <% } %>
                                                    </td>
                                                    <td class="text-muted fw-semibold">
                                                        <%= task.deadline %>
                                                    </td>
                                                    <td>
                                                        <% if(task.status==='Completed' ) { %>
                                                            <span
                                                                class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 status-chip">Completed</span>
                                                            <% } else if(task.status==='In Progress' ) { %>
                                                                <span
                                                                    class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 status-chip">In
                                                                    Progress</span>
                                                                <% } else { %>
                                                                    <span
                                                                        class="badge bg-light text-dark border status-chip">Pending</span>
                                                                    <% } %>
                                                    </td>
                                                    <td class="text-end">
                                                        <a href="/task/edit/<%= task.id %>"
                                                            class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                                        <form action="/task/complete/<%= task.id %>" method="POST"
                                                            class="d-inline">
                                                            <% if(task.status==='Completed' ) { %>
                                                                <button type="submit"
                                                                    class="btn btn-sm btn-outline-secondary me-1">Undo</button>
                                                                <% } else { %>
                                                                    <button type="submit"
                                                                        class="btn btn-sm btn-outline-success me-1">Complete</button>
                                                                    <% } %>
                                                        </form>
                                                        <form action="/task/delete/<%= task.id %>" method="POST"
                                                            class="d-inline"
                                                            onsubmit="return confirm('Are you sure you want to delete this task? This cannot be undone.');">
                                                            <button type="submit"
                                                                class="btn btn-sm btn-outline-danger">Delete</button>
                                                        </form>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <div id="noTaskResults" class="text-center py-5 text-muted d-none">
                            <div class="mb-3 fs-1">🔍</div>
                            <div class="fw-semibold mb-2">No matching tasks</div>
                            <div>Try a different search term.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script id="tasks-data" type="application/json">
<%- JSON.stringify(tasks || []) %>
</script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            const tasks = JSON.parse(document.getElementById('tasks-data').textContent || '[]');
            const calendarGrid = document.getElementById('calendarGrid');
            const upcomingList = document.getElementById('upcomingList');
            const calendarMonth = document.getElementById('calendarMonth');
            const prevMonthBtn = document.getElementById('prevMonth');
            const nextMonthBtn = document.getElementById('nextMonth');
            const taskSearchInput = document.getElementById('taskSearchInput');
            const moduleFilterSelect = document.getElementById('moduleFilterSelect');
            const taskSortSelect = document.getElementById('taskSortSelect');
            const tasksTableBody = document.getElementById('tasksTableBody');
            const noTaskResults = document.getElementById('noTaskResults');

            const weekdayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
            const today = new Date();
            let currentMonth = today.getMonth();
            let currentYear = today.getFullYear();

            // Treat deadlines as date-only values to prevent timezone shifts.
            function normalizeDateOnly(value) {
                if (!value) return '';

                const textValue = String(value);

                // MySQL/Express may return YYYY-MM-DD or YYYY-MM-DDTHH:mm:ss...
                const directMatch = textValue.match(/^(\d{4})-(\d{2})-(\d{2})/);
                if (directMatch) {
                    return `${directMatch[1]}-${directMatch[2]}-${directMatch[3]}`;
                }

                const parsedDate = new Date(value);
                if (Number.isNaN(parsedDate.getTime())) return '';

                const year = parsedDate.getFullYear();
                const month = String(parsedDate.getMonth() + 1).padStart(2, '0');
                const day = String(parsedDate.getDate()).padStart(2, '0');

                return `${year}-${month}-${day}`;
            }

            function makeDateKey(year, monthIndex, day) {
                const month = String(monthIndex + 1).padStart(2, '0');
                const date = String(day).padStart(2, '0');

                return `${year}-${month}-${date}`;
            }

            function parseDateOnly(value) {
                const normalized = normalizeDateOnly(value);
                if (!normalized) return null;

                const [year, month, day] = normalized.split('-').map(Number);
                return new Date(year, month - 1, day);
            }

            const taskMap = tasks.reduce((map, task) => {
                const key = normalizeDateOnly(task.deadline);

                if (key) {
                    map[key] = map[key] || [];
                    map[key].push(task.title);
                }

                return map;
            }, {});

            function formatMonthYear(month, year) {
                return new Date(year, month).toLocaleDateString(undefined, { month: 'long', year: 'numeric' });
            }

            function renderCalendar(month, year) {
                calendarGrid.innerHTML = '';
                calendarMonth.textContent = formatMonthYear(month, year);

                weekdayLabels.forEach(day => {
                    const header = document.createElement('div');
                    header.className = 'day-name';
                    header.textContent = day;
                    calendarGrid.appendChild(header);
                });

                const firstDayIndex = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();

                for (let i = 0; i < firstDayIndex; i++) {
                    const emptyCell = document.createElement('div');
                    emptyCell.className = 'calendar-day empty';
                    calendarGrid.appendChild(emptyCell);
                }

                for (let day = 1; day <= daysInMonth; day++) {
                    const date = new Date(year, month, day);
                    const key = makeDateKey(year, month, day);
                    const dayCell = document.createElement('div');
                    dayCell.className = 'calendar-day';
                    dayCell.dataset.date = key;

                    if (date.toDateString() === today.toDateString()) {
                        dayCell.classList.add('today');
                    }

                    const number = document.createElement('div');
                    number.className = 'date-number';
                    number.textContent = day;
                    dayCell.appendChild(number);

                    const events = taskMap[key] || [];
                    events.slice(0, 2).forEach(title => {
                        const event = document.createElement('div');
                        event.className = 'calendar-event';
                        event.textContent = title;
                        dayCell.appendChild(event);
                    });

                    if (events.length > 2) {
                        const more = document.createElement('div');
                        more.className = 'calendar-more';
                        more.textContent = `+${events.length - 2} more`;
                        dayCell.appendChild(more);
                    }

                    dayCell.addEventListener('click', () => {
                        window.location.href = `/task/add?deadline=${key}`;
                    });

                    calendarGrid.appendChild(dayCell);
                }
            }

            prevMonthBtn.addEventListener('click', () => {
                currentMonth -= 1;
                if (currentMonth < 0) {
                    currentMonth = 11;
                    currentYear -= 1;
                }
                renderCalendar(currentMonth, currentYear);
            });

            nextMonthBtn.addEventListener('click', () => {
                currentMonth += 1;
                if (currentMonth > 11) {
                    currentMonth = 0;
                    currentYear += 1;
                }
                renderCalendar(currentMonth, currentYear);
            });

            renderCalendar(currentMonth, currentYear);

            const startOfToday = new Date(
                today.getFullYear(),
                today.getMonth(),
                today.getDate()
            );

            const upcomingTasks = tasks
                .map(task => ({
                    ...task,
                    deadlineKey: normalizeDateOnly(task.deadline),
                    dueDate: parseDateOnly(task.deadline)
                }))
                .filter(task => task.dueDate && task.dueDate >= startOfToday)
                .sort((a, b) => a.dueDate - b.dueDate)
                .slice(0, 4);

            if (upcomingTasks.length === 0) {
                upcomingList.innerHTML = '<div class="text-muted">No upcoming deadlines</div>';
            } else {
                upcomingTasks.forEach(task => {
                    const item = document.createElement('div');
                    item.className = 'mb-3';
                    item.innerHTML = `
                <div class="fw-semibold">${task.title}</div>
                <div class="text-muted small">${task.deadlineKey}</div>
            `;
                    upcomingList.appendChild(item);
                });
            }

            // --- Task search, module filter, and sort ---
            if (taskSearchInput && tasksTableBody) {
                const taskRows = Array.from(tasksTableBody.querySelectorAll('tr'))
                    .filter(row => !row.querySelector('td[colspan]')); // exclude the "no tasks yet" placeholder row

                const statusOrder = { 'Pending': 0, 'In Progress': 1, 'Completed': 2 };

                // Populate module filter options from whatever modules actually appear
                if (moduleFilterSelect && taskRows.length > 0) {
                    const modules = Array.from(new Set(taskRows.map(row => row.dataset.module).filter(Boolean))).sort();
                    modules.forEach(mod => {
                        const option = document.createElement('option');
                        option.value = mod;
                        option.textContent = mod;
                        moduleFilterSelect.appendChild(option);
                    });
                }

                function applyFiltersAndSort() {
                    const query = taskSearchInput.value.trim().toLowerCase();
                    const moduleValue = moduleFilterSelect ? moduleFilterSelect.value : '';
                    const sortValue = taskSortSelect ? taskSortSelect.value : 'deadline-asc';

                    const sortedRows = [...taskRows].sort((a, b) => {
                        if (sortValue === 'status') {
                            const orderA = statusOrder[a.dataset.status] ?? 99;
                            const orderB = statusOrder[b.dataset.status] ?? 99;
                            return orderA - orderB;
                        }
                        const dateA = parseDateOnly(a.dataset.deadline);
                        const dateB = parseDateOnly(b.dataset.deadline);

                        if (!dateA && !dateB) return 0;
                        if (!dateA) return 1;
                        if (!dateB) return -1;

                        return sortValue === 'deadline-desc'
                            ? dateB - dateA
                            : dateA - dateB;
                    });

                    sortedRows.forEach(row => tasksTableBody.appendChild(row));

                    let visibleCount = 0;
                    sortedRows.forEach(row => {
                        const matchesQuery = row.textContent.toLowerCase().includes(query);
                        const matchesModule = !moduleValue || row.dataset.module === moduleValue;
                        const visible = matchesQuery && matchesModule;
                        row.classList.toggle('d-none', !visible);
                        if (visible) visibleCount += 1;
                    });

                    if (noTaskResults) {
                        noTaskResults.classList.toggle('d-none', visibleCount !== 0);
                    }
                }

                taskSearchInput.addEventListener('input', applyFiltersAndSort);
                if (moduleFilterSelect) moduleFilterSelect.addEventListener('change', applyFiltersAndSort);
                if (taskSortSelect) taskSortSelect.addEventListener('change', applyFiltersAndSort);

                applyFiltersAndSort();
            }
        </script>

</body>

</html>