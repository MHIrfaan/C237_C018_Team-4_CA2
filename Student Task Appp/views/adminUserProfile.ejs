<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile - StudyTrack Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f4f7f6;
            color: #2b3440;
        }

        .navbar-admin {
            background: linear-gradient(135deg, #1e293b, #0f172a);
        }

        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        }

        .profile-picture {
            width: 130px;
            height: 130px;
            object-fit: cover;
            border: 4px solid #ffffff;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.12);
        }

        .btn {
            border-radius: 8px;
            font-weight: 600;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-dark navbar-admin py-3">
    <div class="container">
        <a href="/admin" class="navbar-brand fw-bold">StudyTrack Admin</a>

        <div class="d-flex align-items-center gap-3">
            <span class="text-white">
                <%= user.username %>
            </span>

            <a href="/logout" class="btn btn-sm btn-light">Logout</a>
        </div>
    </div>
</nav>

<div class="container py-5">
    <a href="/admin" class="btn btn-outline-secondary mb-4">
        Back to Admin Dashboard
    </a>

    <div class="card p-4 mb-4">
        <div class="row align-items-center">
            <div class="col-md-3 text-center mb-4 mb-md-0">
                <img
                    src="/images/<%= profileUser.profile_pic || 'profile_icon.webp' %>"
                    onerror="this.onerror=null; this.src='/images/profile_icon.webp';"
                    class="rounded-circle profile-picture"
                    alt="Profile picture"
                >
            </div>

            <div class="col-md-9">
                <h2 class="fw-bold mb-1">
                    <%= profileUser.username %>
                </h2>

                <span class="badge <%= profileUser.role === 'admin' ? 'bg-danger' : 'bg-primary' %> mb-4">
                    <%= profileUser.role %>
                </span>

                <div class="row g-3">
                    <div class="col-md-6">
                        <strong>Email</strong>
                        <div class="text-muted"><%= profileUser.email %></div>
                    </div>

                    <div class="col-md-6">
                        <strong>Contact</strong>
                        <div class="text-muted"><%= profileUser.contact || 'Not provided' %></div>
                    </div>

                    <div class="col-12">
                        <strong>Address</strong>
                        <div class="text-muted"><%= profileUser.address || 'Not provided' %></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card overflow-hidden">
        <div class="card-header bg-white p-4">
            <h4 class="fw-bold mb-0">User Tasks</h4>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Module</th>
                        <th>Type</th>
                        <th>Priority</th>
                        <th>Deadline</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    <% if (tasks.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                This user has no tasks.
                            </td>
                        </tr>
                    <% } else { %>
                        <% tasks.forEach(task => { %>
                            <tr>
                                <td><%= task.title %></td>
                                <td><%= task.module %></td>
                                <td><%= task.task_type %></td>
                                <td><%= task.priority %></td>
                                <td><%= task.deadline %></td>
                                <td><%= task.status %></td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>